paths:
  # Map nested source roots to shadow roots used by Radarr and/or Sonarr.
  root_mappings:
    - nested_root: "/data/movies/age_06"
      shadow_root: "/data/radarr_library/age_06"
    - nested_root: "/data/movies/age_12"
      shadow_root: "/data/radarr_library/age_12"
    - nested_root: "/data/movies/age_16"
      shadow_root: "/data/radarr_library/age_16"
  # Optional gitignore-style patterns (relative to each nested_root) to skip
  # during movie/series discovery. Useful for trash/temp folders like TMM deletes.
  exclude_paths:
    - ".deletedByTMM/"
    - ".trash/"
    - ".librariarr/**"

radarr:
  # Enabled by default. Disable for Sonarr-only mode.
  enabled: true
  # Env overrides: LIBRARIARR_RADARR_URL, LIBRARIARR_RADARR_API_KEY.
  url: "http://radarr:7878"
  api_key: "YOUR_API_KEY"
  sync_enabled: true
  # Per-movie RefreshMovie debounce window in seconds (0 disables debounce).
  refresh_debounce_seconds: 15
  # Auto-add unmatched folders to Radarr.
  auto_add_unmatched: true
  # Optional fixed profile ID; leave commented to auto-map.
  # auto_add_quality_profile_id: 1
  # Trigger indexer search immediately after add.
  auto_add_search_on_add: false
  # Initial monitored flag for newly auto-added movies.
  auto_add_monitored: true

  mapping:
    # Optional fallback map for quality-definition IDs.
    # Used when auto profile mapping has no custom-format signal and
    # parse-based quality-definition signal is unavailable or not mappable.
    # Keep this short; first match wins; all tokens in `match` must be present.
    # target_id values are Radarr quality definition IDs.
    quality_map:
      - match: ["2160p", "x265"]
        target_id: 19
      - match: ["1080p", "x265"]
        target_id: 7
      - match: ["1080p"]
        target_id: 9
      - match: ["720p"]
        target_id: 5

    # Optional: map local analysis tokens (filename/NFO/ffprobe) to Radarr custom format IDs.
    # This is used when auto profile mapping is enabled and helps when Radarr parse
    # cannot infer custom formats from release title alone.
    custom_format_map:
      - match: ["german"]
        format_id: 42
      - match: ["2160p", "x265"]
        format_id: 99

sonarr:
  # Disabled by default. Enable for series path syncing.
  enabled: false
  # Env overrides: LIBRARIARR_SONARR_URL, LIBRARIARR_SONARR_API_KEY.
  url: "http://sonarr:8989"
  api_key: "YOUR_API_KEY"
  sync_enabled: true
  # Per-series RefreshSeries debounce window in seconds (0 disables debounce).
  refresh_debounce_seconds: 15
  # Auto-add unmatched series folders to Sonarr.
  auto_add_unmatched: false
  # Optional fixed profile IDs; leave commented to use lowest available profile IDs.
  # auto_add_quality_profile_id: 1
  # auto_add_language_profile_id: 1
  # Trigger indexer search immediately after add.
  auto_add_search_on_add: false
  # Initial monitored flag for newly auto-added series.
  auto_add_monitored: true
  # Whether newly added series should use season folders in Sonarr.
  auto_add_season_folder: true

  mapping:
    # Optional: token-based quality profile selection for Sonarr auto-add.
    # Only used when sonarr.auto_add_quality_profile_id is not set.
    quality_profile_map:
      - match: ["2160p", "x265"]
        profile_id: 12
      - match: ["1080p"]
        profile_id: 8

    # Optional: token-based language profile selection for Sonarr auto-add.
    # Only used when sonarr.auto_add_language_profile_id is not set.
    language_profile_map:
      - match: ["german", "lang-de"]
        profile_id: 4
      - match: ["lang-de", "lang-en"]
        profile_id: 6

ingest:
  # Move real folders from shadow roots back into nested roots.
  # Requires a 1:1 mapping between each shadow_root and nested_root.
  enabled: true
  # Minimum stable age before ingest.
  min_age_seconds: 300
  # Collision policy: qualify appends [ingest-N], skip leaves source in shadow.
  collision_policy: "qualify"
  # Optional path for failed ingest recovery.
  quarantine_root: "/data/movies/.librariarr/quarantine"

cleanup:
  remove_orphaned_links: true
  # What to do in Radarr when a source folder is missing:
  #   none      -> do not touch Radarr state (recommended for transient outages/renames)
  #   unmonitor -> unmonitor after grace window
  #   delete    -> delete from Radarr after grace window
  radarr_action_on_missing: "none"
  # What to do in Sonarr when a source folder is missing:
  #   none      -> do not touch Sonarr state (recommended for transient outages/renames)
  #   unmonitor -> unmonitor after grace window
  #   delete    -> delete from Sonarr after grace window
  sonarr_action_on_missing: "none"
  # Grace period before unmonitor/delete action is applied.
  missing_grace_seconds: 21600

runtime:
  # Debounce window for filesystem event bursts (seconds).
  debounce_seconds: 8
  # Minutes between full maintenance reconciles (0 = startup-only + events).
  # Note: ingest min_age deferrals still schedule temporary debounced retries.
  maintenance_interval_minutes: 0
  # Minutes between Arr root-folder checks used to auto-trigger reconcile when
  # configured shadow roots are added later in Radarr/Sonarr (0 disables polling).
  arr_root_poll_interval_minutes: 1
  # File extensions used to detect movie folders.
  scan_video_extensions: ["mkv", "mp4", "avi", "m2ts", "mov", "wmv", "ts"]

analysis:
  # Include NFO text in quality detection.
  use_nfo: false
  # Include ffprobe tokens in quality detection.
  use_media_probe: true
  # ffprobe executable name or absolute path.
  media_probe_bin: "ffprobe"
