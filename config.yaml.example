paths:
  # Radarr mappings: your curated tree (managed_root) <-> Radarr's flat root
  # folder (library_root). One pair per bucket.
  movie_root_mappings:
    - managed_root: "/data/movies/age_06"
      library_root: "/data/radarr_library/age_06"
    - managed_root: "/data/movies/age_12"
      library_root: "/data/radarr_library/age_12"
    - managed_root: "/data/movies/age_16"
      library_root: "/data/radarr_library/age_16"

  # Sonarr mappings (required only when sonarr.enabled=true).
  series_root_mappings:
    - managed_root: "/data/series/age_06"
      library_root: "/data/sonarr_library/age_06"
    - managed_root: "/data/series/age_12"
      library_root: "/data/sonarr_library/age_12"

  # Patterns excluded from sync and discovery (case-insensitive).
  # "name/" excludes any directory segment with that name, other patterns are
  # filename globs, absolute paths exclude that subtree.
  # LibrariArr always adds its own defaults (.deletedByLibrariarr/, sample
  # patterns, ...) on top of this list.
  exclude_paths:
    - ".deletedByTMM/"
    - ".actors/"
    - ".trash/"
    - "extras/"
    - "featurettes/"
    - "bonus/"
    - "trailer/"
    - "trailers/"
    - "*-trailer.*"

radarr:
  enabled: true
  # Env overrides: LIBRARIARR_RADARR_URL, LIBRARIARR_RADARR_API_KEY.
  url: "http://radarr:7878"
  api_key: "YOUR_API_KEY"
  sync_enabled: true
  # Per-movie RefreshMovie debounce window in seconds (0 disables debounce).
  refresh_debounce_seconds: 15
  # Auto-add unmatched managed folders to Radarr (exact title+year match only).
  # Requires auto_add_quality_profile_id. Ambiguous folders are reported
  # instead; resolve them by adding the title in the Radarr UI.
  auto_add_unmatched: true
  # auto_add_quality_profile_id: 1
  auto_add_search_on_add: false
  auto_add_monitored: true
  request_timeout_seconds: 120
  request_retry_attempts: 1
  request_retry_backoff_seconds: 1.0
  projection:
    managed_video_extensions: [".mkv", ".mp4", ".avi", ".m2ts", ".mov"]
    managed_extras_allowlist:
      - "*.srt"
      - "*.sub"
      - "movie.nfo"
      - "poster.jpg"
      - "fanart.jpg"

sonarr:
  enabled: false
  # Env overrides: LIBRARIARR_SONARR_URL, LIBRARIARR_SONARR_API_KEY.
  url: "http://sonarr:8989"
  api_key: "YOUR_API_KEY"
  sync_enabled: true
  refresh_debounce_seconds: 15
  auto_add_unmatched: false
  # auto_add_quality_profile_id: 1
  # auto_add_language_profile_id: 1
  auto_add_search_on_add: false
  auto_add_monitored: true
  auto_add_season_folder: true
  request_timeout_seconds: 30
  request_retry_attempts: 2
  request_retry_backoff_seconds: 0.5
  projection:
    managed_video_extensions: [".mkv", ".mp4", ".avi", ".m2ts", ".mov"]
    managed_extras_allowlist:
      - "*.srt"
      - "*.ass"
      - "*.sub"
      - "series.nfo"
      - "tvshow.nfo"
      - "poster.jpg"
      - "fanart.jpg"

runtime:
  # Debounce window for webhook bursts (seconds).
  debounce_seconds: 8
  # Seconds between cheap consistency passes (no tree walk; per-item stat
  # verification). Webhooks additionally trigger this pass instantly.
  consistency_interval_seconds: 300
  # Minutes between full passes (one managed-tree walk + discovery/auto-add
  # + stale-projection prune). This is what picks up manual folder drops.
  full_interval_minutes: 60
  # Reconcile scope at startup: full | consistency | off
  startup_scope: "full"

ingest:
  # Bring new Radarr/Sonarr imports and upgrades into the managed tree by
  # hardlinking them (Arr's files are never moved or renamed).
  enabled: true
  # Behavior for superseded managed files after an upgrade:
  # - soft: move to <managed_root>/.deletedByLibrariarr (default)
  # - hard: delete
  replacement_delete_mode: "soft"
