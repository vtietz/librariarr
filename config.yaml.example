paths:
  # Map nested source roots to Radarr shadow roots.
  root_mappings:
    - nested_root: "/data/movies/age_06"
      shadow_root: "/data/radarr_library/age_06"
    - nested_root: "/data/movies/age_12"
      shadow_root: "/data/radarr_library/age_12"
    - nested_root: "/data/movies/age_16"
      shadow_root: "/data/radarr_library/age_16"

radarr:
  # Env overrides: LIBRARIARR_RADARR_URL, LIBRARIARR_RADARR_API_KEY.
  url: "http://radarr:7878"
  api_key: "YOUR_API_KEY"
  sync_enabled: true
  # Auto-add unmatched folders to Radarr.
  auto_add_unmatched: true
  # Optional fixed profile ID; leave commented to auto-map.
  # auto_add_quality_profile_id: 1
  # Trigger indexer search immediately after add.
  auto_add_search_on_add: false
  # Initial monitored flag for newly auto-added movies.
  auto_add_monitored: true

ingest:
  # Move real folders from shadow roots back into nested roots.
  # Requires a 1:1 mapping between each shadow_root and nested_root.
  enabled: true
  # Minimum stable age before ingest.
  min_age_seconds: 300
  # Collision policy: qualify appends [ingest-N], skip leaves source in shadow.
  collision_policy: "qualify"
  # Optional path for failed ingest recovery.
  quarantine_root: "/data/movies/.librariarr/quarantine"

quality_map:
  # First match wins; all tokens in `match` must be present.
  # Keep rules short and probe-friendly.
  # See docs/configuration.md for target_id lookup.
  - match: ["2160p", "x265"]
    target_id: 13
    name: "4K HEVC"
  - match: ["1080p", "x265"]
    target_id: 7
    name: "1080p HEVC"
  - match: ["1080p"]
    target_id: 6
    name: "1080p"
  - match: ["720p"]
    target_id: 5
    name: "720p"

cleanup:
  remove_orphaned_links: true
  unmonitor_on_delete: true
  delete_from_radarr_on_missing: false

runtime:
  # Debounce window for filesystem event bursts (seconds).
  debounce_seconds: 8
  # Minutes between full maintenance reconciles (0 = startup-only + events).
  maintenance_interval_minutes: 0
  # File extensions used to detect movie folders.
  scan_video_extensions: [".mkv", ".mp4", ".avi", ".m2ts", ".mov", ".wmv", ".ts"]

analysis:
  # Include NFO text in quality detection.
  use_nfo: false
  # Include ffprobe tokens in quality detection.
  use_media_probe: true
  # ffprobe executable name or absolute path.
  media_probe_bin: "ffprobe"
