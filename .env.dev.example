# Dev environment example for: ./run.sh dev-up
# Copy to .env in repo root before starting the dev stack.

# Host user/group mapping used by linuxserver/radarr and linuxserver/sonarr containers.
PUID=1000
PGID=1000
TZ=Etc/UTC

# Dev web/API ports
LIBRARIARR_WEB_PORT=8787
LIBRARIARR_UI_DEV_URL=http://localhost:5173
LIBRARIARR_UI_API_PROXY_TARGET=http://librariarr-dev:8787
DEV_HOST_PORT_RADARR=17878
DEV_HOST_PORT_SONARR=18989

# Internal container URLs used by LibrariArr dev API service
LIBRARIARR_DEV_RADARR_URL=http://radarr-dev:7878
LIBRARIARR_DEV_SONARR_URL=http://sonarr-dev:8989

# Fill these after first Radarr/Sonarr boot (Settings > General > Security)
LIBRARIARR_RADARR_API_KEY=
LIBRARIARR_SONARR_API_KEY=

# Optional log level for LibrariArr API service
LIBRARIARR_LOG_LEVEL=DEBUG

# Host media path mounted into all dev services at /data
# You can keep this local to the repository for easy testing.
MEDIA_ROOT=./data/dev-media
