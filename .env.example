# Copy to .env and adjust values.

# Radarr API settings
LIBRARIARR_RADARR_URL=http://radarr:7878
LIBRARIARR_RADARR_API_KEY=YOUR_API_KEY
LIBRARIARR_RADARR_SYNC_ENABLED=true
LIBRARIARR_DELETE_FROM_RADARR_ON_MISSING=false
LIBRARIARR_USE_NFO_ANALYSIS=false
LIBRARIARR_USE_MEDIA_PROBE=false
LIBRARIARR_MEDIA_PROBE_BIN=ffprobe

# Optional overrides
LIBRARIARR_SHADOW_ROOT=/data/radarr_library
LIBRARIARR_NESTED_ROOTS=/data/movies/age_06,/data/movies/age_12,/data/movies/age_16
LIBRARIARR_LOG_LEVEL=INFO

# Host path mappings used by docker-compose
MOVIES_HOST_PATH=/data/movies
RADARR_LIBRARY_HOST_PATH=/data/radarr_library
