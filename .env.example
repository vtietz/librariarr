# Copy to .env and adjust values.

# Host user/group mapping for file and symlink ownership.
PUID=1000
PGID=1000
TZ=Etc/UTC

# App settings are read from config.yaml, except these optional deployment overrides.
LIBRARIARR_RADARR_URL=http://radarr:7878
LIBRARIARR_RADARR_API_KEY=YOUR_API_KEY
LIBRARIARR_SONARR_URL=http://sonarr:8989
LIBRARIARR_SONARR_API_KEY=YOUR_API_KEY
# Optional projection state DB overrides.
# Newer versions default to /config/*.db automatically when /config is mounted.
LIBRARIARR_PROJECTION_STATE_PATH=/config/librariarr-state.db
LIBRARIARR_SONARR_PROJECTION_STATE_PATH=/config/librariarr-sonarr-state.db

# Optional runtime logging level for docker compose command interpolation.
LIBRARIARR_LOG_LEVEL=INFO
LIBRARIARR_WEB_PORT=8787

# Optional dev-stack defaults used by ./run.sh dev-up (API + UI + local Arr instances).
LIBRARIARR_DEV_RADARR_URL=http://radarr-dev:7878
LIBRARIARR_DEV_SONARR_URL=http://sonarr-dev:8989
DEV_HOST_PORT_RADARR=17878
DEV_HOST_PORT_SONARR=18989

# Best practice: mount one single top-level media root to /data in all related containers.
# Example layout inside MEDIA_ROOT:
#   /data/movies
#   /data/radarr_library
#   /data/sonarr_library
MEDIA_ROOT=/data

# Optional values for full-stack example compose file:
CONFIG_ROOT=./data

# PORTS
HOST_PORT_SABNZBD=8080
HOST_PORT_RADARR=7878
HOST_PORT_SONARR=8989
HOST_PORT_PROWLARR=9696
HOST_PORT_MEDIATHEKARR=5007
HOST_PORT_TRAILARR=5008
HOST_PORT_LIBRARIARR=8787

# Optional VPN/gluetun placeholders for the full-stack example compose file:
# Uncomment and set values only if you enable the gluetun service.
# VPN_SERVICE_PROVIDER=custom
# VPN_TYPE=wireguard
# OPENVPN_CUSTOM_CONFIG=your-config.ovpn
# FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24
# WIREGUARD_PRIVATE_KEY=YOUR_PRIVATE_KEY
# WIREGUARD_ADDRESSES=10.0.0.2/32
# WIREGUARD_PUBLIC_KEY=YOUR_PEER_PUBLIC_KEY
# WIREGUARD_ENDPOINT_IP=vpn.example.com
# WIREGUARD_ENDPOINT_PORT=51820
