# Copy to .env and adjust values.

# Host user/group mapping for file and symlink ownership.
PUID=1000
PGID=1000

# App settings are read from config.yaml, except these optional deployment overrides.
LIBRARIARR_RADARR_URL=http://radarr:7878
LIBRARIARR_RADARR_API_KEY=YOUR_API_KEY

# Optional runtime logging level for docker compose command interpolation.
LIBRARIARR_LOG_LEVEL=INFO

# Host path mappings used by docker-compose
MOVIES_HOST_PATH=/data/movies
# Must be mounted to the same in-container path in both Radarr and LibrariArr.
# Default in-container path in this repo is /data/radarr_library.
# If you use a custom shadow path (for example /data/flat), keep it identical across containers
# and update config.yaml radarr.shadow_root accordingly.
RADARR_LIBRARY_HOST_PATH=/data/radarr_library
